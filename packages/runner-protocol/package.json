{
  "name": "@yasui.io/runner-protocol",
  "version": "0.1.0",
  "description": "Yasui relay/v1 wire protocol — types, zod schemas, conformance fixtures",
  "author": {
    "name": "BlueAlitas",
    "email": "BlueAlitas@proton.me"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/yasui-io/runner#readme",
  "bugs": {
    "url": "https://github.com/yasui-io/runner/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasui-io/runner.git",
    "directory": "packages/runner-protocol"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "fixtures"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts --target=node --format=esm --outdir=dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "5.7.3",
    "vitest": "^4.0.15"
  }
}
