{
  "name": "@yasui.io/runner",
  "version": "0.1.0",
  "description": "Yasui agent host — runs coding-agent sessions on your machine, driven from the Yasui web UI",
  "author": {
    "name": "BlueAlitas",
    "email": "BlueAlitas@proton.me"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/yasui-io/runner#readme",
  "bugs": {
    "url": "https://github.com/yasui-io/runner/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yasui-io/runner.git",
    "directory": "packages/runner"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "bin": {
    "yasui-runner": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "bun build ./src/cli/index.ts --outdir ./dist/cli --target node --format esm --external @anthropic-ai/claude-agent-sdk --external ws --external pino --external commander --external zod"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.202",
    "@yasui.io/runner-protocol": "0.1.0",
    "commander": "^14.0.2",
    "pino": "^10.1.0",
    "ws": "^8.18.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.0",
    "typescript": "5.7.3",
    "vitest": "^4.0.15"
  }
}
